{
    "kind": "collectionType",
    "collectionName": "reviews",
    "info": {
        "singularName": "review",
        "pluralName": "reviews",
        "displayName": "Review",
        "description": "User reviews"
    },
    "options": {
        "draftAndPublish": true
    },
    "attributes": {
        "user": {
            "type": "string",
            "required": true
        },
        "rating": {
            "type": "integer",
            "min": 1,
            "max": 5,
            "default": 5
        },
        "comment": {
            "type": "text",
            "required": true
        },
        "role": {
            "type": "string"
        },
        "date": {
            "type": "string"
        }
    }
}
