---
---
<nav class="space-y-1 bg-card border border-border rounded-xl p-4 shadow-sm">
  <h3 class="px-3 text-xs font-semibold text-muted-foreground uppercase tracking-wider mb-4">Ajustes de Cuenta</h3>
  <a href="#profile" class="tab-link flex items-center px-3 py-2 text-sm font-medium rounded-md bg-muted text-foreground transition-colors" data-target="profile-section">
    <svg class="mr-3 flex-shrink-0 h-5 w-5 text-foreground" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
    </svg>
    Perfil
  </a>
  <a href="#security" class="tab-link flex items-center px-3 py-2 text-sm font-medium rounded-md text-muted-foreground hover:bg-muted hover:text-foreground transition-colors" data-target="security-section">
    <svg class="mr-3 flex-shrink-0 h-5 w-5 text-muted-foreground group-hover:text-foreground" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
    </svg>
    Seguridad
  </a>
  <a href="#billing" class="tab-link flex items-center px-3 py-2 text-sm font-medium rounded-md text-muted-foreground hover:bg-muted hover:text-foreground transition-colors" data-target="billing-section">
    <svg class="mr-3 flex-shrink-0 h-5 w-5 text-muted-foreground group-hover:text-foreground" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z" />
    </svg>
    Facturación
  </a>
  <a href="#notifications" class="tab-link flex items-center px-3 py-2 text-sm font-medium rounded-md text-muted-foreground hover:bg-muted hover:text-foreground transition-colors" data-target="notifications-section">
    <svg class="mr-3 flex-shrink-0 h-5 w-5 text-muted-foreground group-hover:text-foreground" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9" />
    </svg>
    Notificaciones
  </a>
  
  <div class="pt-4 mt-4 border-t border-border">
    <a href="#danger" class="tab-link flex items-center px-3 py-2 text-sm font-medium rounded-md text-destructive hover:bg-destructive/10 transition-colors" data-target="danger-section">
      <svg class="mr-3 flex-shrink-0 h-5 w-5 text-destructive" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
      </svg>
      Zona de Peligro
    </a>
  </div>
</nav>

<script>
  function setupTabs() {
    const links = document.querySelectorAll('.tab-link');
    const contents = document.querySelectorAll('.tab-content');

    if (!links.length || !contents.length) return;

    function switchTab(hash: string) {
      if (!hash) hash = '#profile';
      const targetId = hash.replace('#', '') + '-section';
      
      contents.forEach(content => {
        if (content.id === targetId) {
          content.classList.remove('hidden');
          content.classList.add('block');
        } else {
          content.classList.add('hidden');
          content.classList.remove('block');
        }
      });

      links.forEach(link => {
        const svg = link.querySelector('svg');
        const isDanger = link.getAttribute('href') === '#danger';
        
        if (link.getAttribute('href') === hash) {
          if (isDanger) {
            link.classList.add('bg-destructive/10');
          } else {
            link.classList.add('bg-muted', 'text-foreground');
            link.classList.remove('text-muted-foreground');
            if (svg) {
                svg.classList.add('text-foreground');
                svg.classList.remove('text-muted-foreground');
            }
          }
        } else {
          if (isDanger) {
            link.classList.remove('bg-destructive/10');
          } else {
            link.classList.remove('bg-muted', 'text-foreground');
            link.classList.add('text-muted-foreground');
            if (svg) {
                svg.classList.remove('text-foreground');
                svg.classList.add('text-muted-foreground');
            }
          }
        }
      });
    }

    links.forEach(link => {
      link.addEventListener('click', (e) => {
        e.preventDefault();
        const hash = link.getAttribute('href');
        if (hash) {
            window.history.pushState(null, '', hash);
            switchTab(hash);
        }
      });
    });

    window.addEventListener('hashchange', () => switchTab(window.location.hash));
    switchTab(window.location.hash);
  }

  document.addEventListener('DOMContentLoaded', setupTabs);
  document.addEventListener('astro:page-load', setupTabs);
</script>
