---
import { Image } from "astro:assets";

const { name, image, url } = Astro.props;
---

<div class="group relative mb-8 overflow-hidden rounded-mb md:mb-8">
  <a href={url}>
    <div
      class="absolute inset-0 z-10 h-full w-full bg-black opacity-20 transition-opacity duration-300 ease-in-out group-hover:opacity-45"
    >
    </div>
    <Image
      src={image}
      alt={name}
      class="rounded-md transition-transform duration-300 ease-in-out group-hover:scale-105"
    />
    <p
      class="absolute bottom-4 left-4 z-20 text-md text-white transition-all duration-300 group-hover:bottom-6 font-medium"
    >
      {name}
    </p>
  </a>
</div>
