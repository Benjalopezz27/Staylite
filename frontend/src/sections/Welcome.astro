---
import ReviewList from "@/components/ReviewList";
---

<section class="pt-10 lg:pt-28 border border-b-muted-foreground/10 pb-16">
  <div class="container">
    <div class="max-w-3xl text-start mx-10">
      <h2 class="text-2xl md:text-4xl font-semibold mb-1">
        Que dicen nuestros huéspedes
      </h2>
      <p class="md:text-lg text-muted-foreground">
        Descubre lo que nuestros huéspedes opinan sobre su experiencia en el
        Hotel StayLite.
      </p>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4 m-10">
      <ReviewList client:visible />
    </div>
  </div>
</section>
