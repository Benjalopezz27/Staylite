---
import ReviewList from "@/components/ReviewList";
import fetchApi from "@/services/strapi";
import type { Review } from "@/lib/types";

// 1. Hacemos el fetch en el servidor de forma segura (sin problemas de CORS ni variables)
let mappedReviews: Review[] = [];

try {
  const response = await fetchApi({
    endpoint: "reviews",
    query: { populate: "*" },
  });

  // 2. Mapeamos la estructura de Strapi (v4 o v5) aquí mismo en el backend
  const dataArray = response?.data || response || [];

  mappedReviews = dataArray.map((item: any) => {
    const attributes = item.attributes || item;
    return {
      user: attributes.user,
      rating: attributes.rating || 5,
      comment: attributes.comment,
      role: attributes.role,
      date: attributes.date,
    };
  });
} catch (error) {
  console.error("Error fetching reviews from Strapi on the server:", error);
}
---

<section class="pt-10 lg:pt-28 border border-b-muted-foreground/10 pb-16">
  <div class="container">
    <div class="max-w-3xl text-start mx-10">
      <h2 class="text-2xl md:text-4xl font-semibold mb-1">
        Que dicen nuestros huéspedes
      </h2>
      <p class="md:text-lg text-muted-foreground">
        Descubre lo que nuestros huéspedes opinan sobre su experiencia en el
        Hotel StayLite.
      </p>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4 m-10">
      {
        /* 3. Pasamos los datos puros a React. Ya no hay tiempos de carga en el cliente */
      }
      <ReviewList reviews={mappedReviews} client:load />
    </div>
  </div>
</section>
