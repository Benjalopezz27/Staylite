---
import Layout from "../layouts/Layout.astro";
import ProfileSettings from "../components/ProfileSettings";
import SecuritySettings from "../components/SecuritySettings";
import BillingSettings from "../components/BillingSettings";
import NotificationSettings from "../components/NotificationSettings";
import DangerZone from "../components/DangerZone";
import AccountNav from "../components/AccountNav.astro";
---

<Layout>
  <div class="container py-10 min-h-screen pt-36">
    <div class="flex flex-col md:flex-row gap-8 max-w-6xl mx-auto">
      <aside class="w-full md:w-64 shrink-0">
        <AccountNav />
      </aside>
      <main class="flex-1">
        <div id="profile-section" class="tab-content block">
          <ProfileSettings client:load />
        </div>
        <div id="security-section" class="tab-content hidden">
          <SecuritySettings client:load />
        </div>
        <div id="billing-section" class="tab-content hidden">
          <BillingSettings client:load />
        </div>
        <div id="notifications-section" class="tab-content hidden">
          <NotificationSettings client:load />
        </div>
        <div id="danger-section" class="tab-content hidden">
          <DangerZone client:load />
        </div>
      </main>
    </div>
  </div>
</Layout>
