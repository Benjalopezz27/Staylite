---
import Reservation from "@/components/Reservation";
import Layout from "@/layouts/Layout.astro";
import { Image } from "astro:assets";
import { ThumbnailsCarousel } from "@/components/ui/signature";
import {
  AirVentIcon,
  BathIcon,
  Camera,
  Coffee,
  Hotel,
  Phone,
  Ruler,
  Tv,
  Wifi,
} from "lucide-react";
import API from "@/services/roomsData";
import type { Room } from "@/lib/types";

export async function getStaticPaths() {
  const rooms = await API.getRooms();
  return rooms.map((room: Room) => ({
    params: { slug: room.slug },
  }));
}
const { slug } = Astro.params;
if (slug === undefined) {
  throw new Error("Slug is undefined");
}

const room = await API.getRoomBySlug(slug);

if (!room) {
  return Astro.redirect("/404");
}

const carouselImages = [
  { full: room.image.src, thumb: room.image.src },
  ...(room.thumbnails || []).map((img) => ({ full: img.src, thumb: img.src })),
];
---

<Layout title={room.name}>
  <div class="container pt-30">
    <div class="mb-8 text-center">
      <h1 class="text-2xl font-semibold mb-4">{room.name}</h1>

      <div class="flex flex-wrap items-center justify-center gap-4">
        {
          room.features.map((feature) => (
            <div class="flex items-center gap-2 justify-center">
              {feature.icon === "bed" && <Hotel className="text-primary" />}
              {feature.icon === "ruler" && <Ruler className="text-primary" />}
              {feature.icon === "camera" && <Camera className="text-primary" />}
              <p>
                {feature.name}: <strong>{feature.value}</strong>
              </p>
            </div>
          ))
        }
      </div>
    </div>
    <div>
      <ThumbnailsCarousel images={carouselImages} client:load />
    </div>
    <div class="mt-16 md:grid md:grid-cols-2 md:gap-8">
      <div>
        <div class="mb-8">
          <h3 class="text-xl font-semibold mb-4">Descripción</h3>
          <p>{room.description}</p>
        </div>
        <div>
          <h3 class="text-xl font-semibold mb-4">Servicios</h3>
          <div class="mb-8 grid grid-cols-2 gap-4">
            {
              room.amenities.map((amenity) => (
                <div class="flex items-center gap-4">
                  {amenity.icon === "wifi" && <Wifi className="text-primary" />}
                  {amenity.icon === "tv" && <Tv className="text-primary" />}
                  {amenity.icon === "ac" && (
                    <AirVentIcon className="text-primary" />
                  )}
                  {amenity.icon === "coffee" && (
                    <Coffee className="text-primary" />
                  )}
                  {amenity.icon === "shower" && (
                    <BathIcon className="text-primary" />
                  )}
                  {amenity.icon === "room-service" && (
                    <Phone className="text-primary" />
                  )}
                  <p>{amenity.name}</p>
                </div>
              ))
            }
          </div>
          <div>
            <h3 class="text-2xl font-semibold mb-4">Reseñas de Clientes</h3>
            <p>Se el primero en dejar un comentario</p>
          </div>
        </div>
      </div>
      <div>
        <Reservation room={room} client:load />
      </div>
    </div>
  </div>
</Layout>
